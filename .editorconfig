root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{c,h,cpp,hpp}]
indent_style = space
indent_size = 4
max_line_length = 150

[*.py]
indent_style = space
indent_size = 4
max_line_length = 150

[vendor/**]
# Untouched third-party code keeps whatever style upstream used.
max_line_length = off
